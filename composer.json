{
    "name": "rheinmaintech/curly-cms",
    "description": "An open-source AI-native Agentic Content Management System.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "RheinMainTech GmbH",
            "email": "support@rheinmaintech.de"
        }
