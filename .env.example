# Application
APP_NAME="Curly CMS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://localhost
APP_KEY=your-secret-key-here-change-in-production

# Database
DB_CONNECTION=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=curlycms
DB_USERNAME=
DB_PASSWORD=

# AI Configuration
AI_PROVIDER=openai
AI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache
CACHE_DRIVER=file
CACHE_LIFETIME=3600

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Curly CMS"

# Security
SECURITY_SALT=change-this-to-a-random-string
SECURITY_CIPHER=aes-256-gcm
